# ── Core ──────────────────────────────────────────────────────────
PORT=4000
DATABASE_URL=postgres://user:password@localhost:5432/dead_mans_switch
PGSSL=false
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Set to "false" to disable the background trigger-evaluation cron job
# (useful if you're running the worker as a separate process/dyno).
ENABLE_TRIGGER_WORKER=true
TRIGGER_CRON=*/5 * * * *

# Base URL used to build beneficiary portal links (scoped_token appended).
PORTAL_BASE_URL=https://app.example.com/portal

# ── AI Digital Executor ──────────────────────────────────────────
# Leave unset to use the built-in template fallback instead of live Claude calls.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# ── Email (SendGrid) ──────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM=no-reply@example.com

# ── SMS (Twilio) ──────────────────────────────────────────────────
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ── Telegram ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── IPFS (Pinata) ─────────────────────────────────────────────────
PINATA_JWT=

# Each LAWYER_API / WEBHOOK release_channel carries its own endpoint + key
# in its JSONB config column, so no global env vars are needed for those.

# ── Heartbeat nodes (server-quorum false-positive safeguard) ──────
# Shared secret each independent infra node (AWS/Fly.io/Railway) presents
# when pinging POST /api/heartbeat. Leave unset to accept unauthenticated
# pings during local dev.
HEARTBEAT_SHARED_SECRET=
